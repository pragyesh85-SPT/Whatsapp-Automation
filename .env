# ── Environment for the coaching WhatsApp-workaround automation ──
# Tuned for this laptop: use the ALREADY-INSTALLED Chrome (no extra download).

# Path to system Chrome (verified present on this machine)
CHROME_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe

# Skip Puppeteer's bundled Chromium download (saves ~170 MB on the tight C: drive)
PUPPETEER_SKIP_DOWNLOAD=true

# Timezone for office-hours / pacing logic
TZ=Asia/Kolkata

# Active tenant (matches tenants/<id>.json)
TENANT_ID=infinity-classes

# Local ports
DASH_PORT=3000
# Public base URL for upload links + Razorpay webhook (use a tunnel URL in real use,
# e.g. a cloudflared / ngrok https URL). For LAN testing use http://<laptop-ip>:3000
PUBLIC_BASE_URL=http://localhost:3000

# ── AI (Gemini 2.5 Flash-Lite) — paste key to switch AI evaluation + analytics ON ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Razorpay — paste keys to switch auto pay-links + receipts ON ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Humanizer knobs (anti-flag suite — see architecture doc PART 1.4) ──
# Pacing between messages (ms) + random jitter on top
SPACING_MS=60000
JITTER_MS=30000
# Daily send cap + warm-up ramp (comma list, last value = steady cap)
WARMUP_RAMP=20,25,30,35,40,45,50
# Office hours (24h, IST)
OFFICE_START_HOUR=9
OFFICE_END_HOUR=20
# Typing simulation window (ms)
TYPING_MIN_MS=1200
TYPING_MAX_MS=3000
